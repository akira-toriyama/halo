#!/bin/sh
# commit-msg hook: validate gitmoji + Conventional Commits form.
# Enable:  git config core.hooksPath scripts/hooks
#
# Form: <:gitmoji:> <type>(<scope>)<!>: <subject>
#   e.g. :sparkles: feat(border): cycle the ring through the neon palette
#
# Mirrors facet's hook (same convention across the family).
# Low-dependency (POSIX sh + grep). gitmoji must be the :code: text form.

msg_file="$1"
subject="$(grep -vE '^[[:space:]]*#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)"

case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

types='feat|fix|perf|refactor|docs|test|build|ci|chore|style|revert'
pattern="^:[a-z0-9][a-z0-9_+-]*: ($types)(\([^()]+\))?!?: .+"

if printf '%s' "$subject" | grep -qE "$pattern"; then
  exit 0
fi

cat >&2 <<EOF
✖ Commit message violates the convention.

  got: $subject

  form: <:gitmoji:> <type>(<scope>)<!>: <subject>
        ^^^^^^^^^^^ :code: text form required (emoji glyph rejected)

  type: $types
  e.g.: :sparkles: feat(border): add the rainbow effect
        :zap: perf(focus): settle-deferred re-resolve
        :bug: fix(config): clamp width to a sane minimum
EOF
exit 1
